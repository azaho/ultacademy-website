						<div class="elementor-container elementor-column-gap-default">
					<div class="elementor-column elementor-col-50 elementor-top-column elementor-element elementor-element-be46e40 exad-glass-effect-no exad-sticky-section-no" data-id="be46e40" data-element_type="column" data-e-type="column">
